
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "System user account with role-based access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "staff", "external", "admin", "superadmin"] },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "classId": { "type": "string" },
        "assignedClasses": { "type": "array", "items": { "type": "string" } },
        "adminApproved": { "type": "boolean" },
        "disabled": { "type": "boolean" },
        "ein": { "type": "string" },
        "studentId": { "type": "string" }
      },
      "required": ["uid", "role"]
    },
    "Notice": {
      "title": "Notice",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["important", "exam", "holiday", "admission", "general"] },
        "teacherUid": { "type": "string" },
        "targetClasses": { "type": "array", "items": { "type": "string" } },
        "isPinned": { "type": "boolean" },
        "attachmentUrl": { "type": "string" }
      }
    },
    "Attendance": {
      "title": "Attendance Record",
      "type": "object",
      "properties": {
        "studentUid": { "type": "string" },
        "classId": { "type": "string" },
        "date": { "type": "string" },
        "isPresent": { "type": "boolean" },
        "markedByUid": { "type": "string" }
      }
    },
    "MasterRecord": {
      "title": "Master Verification List",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "isValid": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profiles managed by rules."
    },
    "/mainNotices/{id}": {
      "schema": { "$ref": "#/backend/entities/Notice" },
      "description": "Official announcements."
    },
    "/teacherNotices/{id}": {
      "schema": { "$ref": "#/backend/entities/Notice" },
      "description": "Class specific notices."
    },
    "/studentMasterList/{id}": {
      "schema": { "$ref": "#/backend/entities/MasterRecord" },
      "description": "Admin-only verification list for students."
    },
    "/teacherMasterList/{id}": {
      "schema": { "$ref": "#/backend/entities/MasterRecord" },
      "description": "Admin-only verification list for teachers."
    },
    "/attendance/{id}": {
      "schema": { "$ref": "#/backend/entities/Attendance" },
      "description": "Student daily attendance."
    },
    "/complaints/{id}": {
      "schema": { "type": "object" },
      "description": "Feedback box submissions."
    },
    "/statistics/{id}": {
      "schema": { "type": "object" },
      "description": "Homepage animated stats."
    }
  }
}
