{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Main user account information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "staff", "external", "admin", "superadmin"] },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "classId": { "type": "string" },
        "assignedClasses": { "type": "array", "items": { "type": "string" } },
        "adminApproved": { "type": "boolean" },
        "disabled": { "type": "boolean" }
      },
      "required": ["uid", "role"]
    },
    "Notice": {
      "title": "Notice",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["important", "exam", "holiday", "admission", "general"] },
        "teacherUid": { "type": "string" },
        "targetClasses": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "System user accounts."
    },
    "/mainNotices/{noticeId}": {
      "schema": { "$ref": "#/backend/entities/Notice" },
      "description": "Official school-wide notices."
    },
    "/teacherNotices/{noticeId}": {
      "schema": { "$ref": "#/backend/entities/Notice" },
      "description": "Class-specific notices from teachers."
    },
    "/slidingNotices/{docId}": {
      "schema": { "type": "object" },
      "description": "Notices for the homepage ticker."
    },
    "/complaints/{complaintId}": {
      "schema": { "type": "object" },
      "description": "Complaint box submissions."
    },
    "/studentProfiles/{uid}": {
      "schema": { "type": "object" },
      "description": "Detailed student academic records."
    },
    "/teacherProfiles/{uid}": {
      "schema": { "type": "object" },
      "description": "Detailed teacher professional records."
    }
  }
}