
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information stored in Firestore.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "staff", "external", "admin", "super_admin"] },
        "status": { "type": "string", "enum": ["active", "inactive", "pending", "locked"] },
        "displayName": { "type": "string" },
        "idNumber": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string" },
        "photoUrl": { "type": "string" },
        "class": { "type": "string" },
        "section": { "type": "string" },
        "rollNumber": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "homeworkRating": { "type": "number" },
        "teacherAvgRating": { "type": "number" },
        "finalRating": { "type": "number" }
      },
      "required": ["uid", "role", "status"]
    },
    "SchoolNotice": {
      "title": "School Notice",
      "description": "Notices for students and staff.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["important", "exam", "holiday", "admission", "general"] },
        "category": { "type": "string", "enum": ["main", "teacher"] },
        "publishedAt": { "type": "string", "format": "date-time" },
        "isPinned": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "attachmentUrl": { "type": "string" },
        "attachmentName": { "type": "string" },
        "attachmentSize": { "type": "string" },
        "authorName": { "type": "string" },
        "authorId": { "type": "string" },
        "targetClasses": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "type", "category", "publishedAt"]
    },
    "AttendanceRecord": {
      "title": "Attendance Record",
      "type": "object",
      "properties": {
        "class": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "presentStudents": { "type": "array", "items": { "type": "string" } },
        "absentStudents": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Homework": {
      "title": "Homework",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "class": { "type": "string" },
        "subject": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "attachmentUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "HomeworkStatus": {
      "title": "Homework Status",
      "type": "object",
      "properties": {
        "homeworkId": { "type": "string" },
        "studentId": { "type": "string" },
        "status": { "type": "string", "enum": ["done", "not_done"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile data."
    },
    "/notices/{noticeId}": {
      "schema": { "$ref": "#/backend/entities/SchoolNotice" },
      "description": "Official school and teacher notices."
    },
    "/attendance/{recordId}": {
      "schema": { "$ref": "#/backend/entities/AttendanceRecord" },
      "description": "Daily attendance logs."
    }
  }
}
